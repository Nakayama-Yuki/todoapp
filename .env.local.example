# ローカル開発環境用 - 上書き設定
# このファイルをコピーして .env.local を作成してください
# git にコミットされません
#
# 用途:
# - Dockerを使わずにローカル開発する場合
# - DATABASE_URL のホスト名を localhost に変更したい場合
# - .env の値をローカル環境で上書きしたい場合

# データベース接続（ローカル開発用 - localhost で接続）
DATABASE_URL=postgresql://todouser:todopass@localhost:5432/todoapp

# Node環境
NODE_ENV=development

# 認証設定（GitHub OAuth）
# AUTH_SECRET は `openssl rand -base64 32` などで生成してください
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
